# --- Server ---
PORT=3010
NODE_ENV=development

# Base domain. Tenant host = <key>-docs.<BASE_DOMAIN>
BASE_DOMAIN=escalia.tech

# --- Database (SQLite default; switch provider in prisma/schema.prisma for Postgres) ---
DATABASE_URL="file:./dev.db"
# Postgres example:
# DATABASE_URL="postgresql://user:pass@localhost:5432/escalia_docs?schema=public"

# --- Storage ---
# Files saved under STORAGE_DIR/<tenantKey>/<uuid>
STORAGE_DIR=./storage
MAX_UPLOAD_MB=50

# --- Super admin (global) ---
# Generate hash: npm run hash -- "your-password"
ADMIN_USER=admin
ADMIN_PASS_HASH=

# --- JWT / cookies ---
# Long random strings. Rotate ADMIN secret to kill admin sessions; TENANT secret to kill reader sessions.
JWT_ADMIN_SECRET=change-me-admin-secret
JWT_READER_SECRET=change-me-reader-secret
ADMIN_TOKEN_TTL=12h
READER_TOKEN_TTL=8h

# Cookie set with domain so it scopes to the tenant host only (subdomain isolation)
COOKIE_SECURE=false
